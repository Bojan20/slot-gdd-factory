{
  "name": "slot-gdd-factory",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "One-button GDD upload → parsed model → playable slot in a new tab. Zero-runtime, vanilla browser.",
  "scripts": {
    "test": "node tests/parse-real.mjs && node tests/render-grid-all.mjs",
    "test:parse": "node tests/parse-real.mjs",
    "test:grids": "node tests/render-grid-all.mjs",
    "test:browser": "node tests/render-browser-all.mjs",
    "test:qa": "node tools/render-grid-gallery.mjs && node tools/full-qa-audit.mjs",
    "test:fs": "node tools/render-grid-gallery.mjs && node tools/fs-qa-audit.mjs",
    "test:all": "npm run test:parse && npm run test:grids && npm run test:browser && npm run test:qa && npm run test:fs",
    "serve": "python3 -m http.server 5180"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "zod": "^4.2.1"
  }
}
